# ──────────────────────────────────────────────────────────────────────────────
# Goove Web — environment variables example
#
# Copy this file to `.env.local` and tweak the values you need.
# `.env.local` is git-ignored (see .gitignore: `.env*.local`).
#
#   cp .env.example .env.local
#
# After changing any variable, restart the Next.js dev server:
#   pnpm dev
# ──────────────────────────────────────────────────────────────────────────────


# ─── Govee LAN adapter ────────────────────────────────────────────────────────

# Master switch for the adapter layer.
# false  -> skip adapter execution (in-memory patch only)
# true   -> use registered adapters (default)
GOVEE_LAN_ADAPTER_ENABLED=true

# Transport used by adapters when sending commands to the device.
#   mock -> no UDP traffic, only updates in-memory state (safe default)
#   udp  -> sends real UDP packets to the device on port 4003
GOVEE_LAN_TRANSPORT=mock

# Optional override for the device control port (Govee LAN spec uses 4003).
# GOVEE_LAN_UDP_PORT=4003


# ─── Govee LAN discovery ──────────────────────────────────────────────────────

# How devices are discovered.
#   mock -> returns a fixed set of fake devices (safe default)
#   udp  -> performs real UDP broadcast discovery on the local network
GOVEE_LAN_DISCOVERY_MODE=mock

# Optional overrides for the discovery layer (Govee LAN spec uses 4001 / broadcast).
# GOVEE_LAN_DISCOVERY_PORT=4001
# GOVEE_LAN_DISCOVERY_BROADCAST=255.255.255.255
# GOVEE_LAN_DISCOVERY_TIMEOUT_MS=1200


# ─── Debug ────────────────────────────────────────────────────────────────────

# Enables verbose logs from lib/govee/* (discovery, adapter, lan-client).
# Useful to understand why the system fell back to mock.
GOVEE_DEBUG=false


# ──────────────────────────────────────────────────────────────────────────────
# Quick recipes
# ──────────────────────────────────────────────────────────────────────────────
#
# 1) Full mock (default, no network traffic):
#      GOVEE_LAN_TRANSPORT=mock
#      GOVEE_LAN_DISCOVERY_MODE=mock
#
# 2) Real LAN (your machine must be on the same network as the Govee devices,
#    and the device must have "LAN Control" enabled in the Govee Home app):
#      GOVEE_LAN_TRANSPORT=udp
#      GOVEE_LAN_DISCOVERY_MODE=udp
#      GOVEE_DEBUG=true
#
# 3) Real discovery, mocked control (useful to inspect what's on the network
#    without sending commands yet):
#      GOVEE_LAN_TRANSPORT=mock
#      GOVEE_LAN_DISCOVERY_MODE=udp
#      GOVEE_DEBUG=true
#
# The system-mode badge in the Dashboard and Devices pages reflects the
# resolved values at runtime, and `GET /api/system/status` exposes them as JSON.
